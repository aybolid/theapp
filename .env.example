# .env file used by docker compose

# pg database

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=theapp_db

# garage

RUST_LOG=info

# garage ui

API_BASE_URL=http://garage:3903
S3_ENDPOINT_URL=http://garage:3900

# server

DATABASE_URL=postgres://postgres:postgres@db:5432/theapp_db
JWT_SECRET=
S3_ENDPOINT=http://garage:3900
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=garage
S3_PUBLIC_BASE_URL=http://theapp.web.garage.localhost:3902
S3_BUCKET=theapp
FROM_EMAIL=noreply@theapp.io
INVITE_REDIRECT_URL=http://localhost:5173/signup

# webapp

VITE_API_BASE_URL=http://localhost:8080
